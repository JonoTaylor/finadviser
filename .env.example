ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgres://user:pass@host/db

# Optional. Overrides the default Claude model.
# CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Auth ---
# Bcrypt hash of the owner's password. Generate with:
#   npm --prefix web run hash-password
# APP_PASSWORD_HASH=$2a$12$...
# Secret used to sign session cookies. 32+ random chars.
# AUTH_SECRET=<random 48+ char string>
# Optional. Session cookie lifetime in seconds (default 2,592,000 = 30 days).
# SESSION_TTL_SECONDS=2592000

# Service-account bearer token (CI, scripts). Accepted by /api/* in
# place of a session cookie. Leave unset if you only need browser login.
# API_AUTH_TOKEN=<random 32+ char string>

# Required to call POST /api/seed. Must also set ALLOW_SEED=true.
# ADMIN_TOKEN=<random 32+ char string>
# ALLOW_SEED=false

# Comma-separated list of origins permitted to call /api/* from a browser.
# Use "*" to allow any origin. Leave unset to disable CORS entirely.
# ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000

# Per-IP per-minute rate limit on /api/* (default 120).
# RATE_LIMIT_PER_MIN=120
